{"bgColorIndex":0,"note":"<!DOCTYPE html>\n<html>\n<head>\n    <title>Jasmine Tic Tac Toe Game<\/title>\n    <style>\n        body { text-align: center; font-family: sans-serif; }\n        .board { display: grid; grid-template-columns: repeat(3, 100px); justify-content: center; gap: 5px; }\n        .cell { width: 100px; height: 100px; border: 2px solid black; font-size: 3em; display: flex; align-items: center; justify-content: center; cursor: pointer; }\n    <\/style>\n<\/head>\n<body>\n    <h1>Jasmine Tic Tac Toe Game<\/h1>\n    <div class=\"board\" id=\"board\">\n        <script>\n            \/\/ Generate cells\n            for(let i=0; i<9; i++) document.write(`<div class=\"cell\" onclick=\"makeMove(this)\"><\/div>`);\n        <\/script>\n    <\/div>\n    <p id=\"status\">Player X's turn<\/p>\n    <script>\n        let turn = 'X', gameOver = false;\n        const cells = document.querySelectorAll('.cell');\n        const winCombos = [[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];\n\n        function makeMove(cell) {\n            if(cell.innerText || gameOver) return;\n            cell.innerText = turn;\n            if(checkWin()) {\n                document.getElementById('status').innerText = `Player ${turn} Wins!`;\n                gameOver = true;\n            } else {\n                turn = turn === 'X' ? 'O' : 'X';\n                document.getElementById('status').innerText = `Player ${turn}'s turn`;\n            }\n        }\n        function checkWin() {\n            return winCombos.some(combo => {\n                return combo.every(index => cells[index].innerText === turn);\n            });\n        }\n    <\/script>\n<\/body>\n<\/html>\n","textColorIndex":1}